# Contoh variabel lingkungan — SALIN ke ".env" lalu sesuaikan.
#   cp .env.example .env      (Linux/macOS)
#   copy .env.example .env    (Windows)
#
# Semua opsional: bila tidak diisi, sistem memakai nilai di config/config.yaml.

# Path berkas konfigurasi utama
PREDIKSI_HAID_CONFIG=config/config.yaml

# Level log: DEBUG | INFO | WARNING | ERROR
PREDIKSI_HAID_LOG_LEVEL=INFO

# Timpa seed acak (kosongkan untuk pakai nilai config: 42)
PREDIKSI_HAID_RANDOM_STATE=42
